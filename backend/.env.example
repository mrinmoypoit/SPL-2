# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=tulona_db

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Email Configuration (for OTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_APP_PASSWORD=your-16-character-google-app-password
# Optional fallback key used by older code paths
EMAIL_PASSWORD=
# Optional: set true if you use port 465
EMAIL_SECURE=false

# SMS Configuration (for OTP)
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=TULONA

# Application Settings
OTP_EXPIRY_MINUTES=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# AI Assistant Configuration (optional)
# Supported providers: ollama | openai | gemini
AI_PROVIDER=ollama

# Ollama (free/open-source local model) settings
# Example: AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_MS=7000

# OpenAI settings
OPENAI_API_KEY= 
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini settings
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
